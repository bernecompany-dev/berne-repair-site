# Resend — get key at https://resend.com/api-keys
RESEND_API_KEY=
# Sandbox until domain verified. Switch to "leads@berne-repair.com" after
# adding SPF/DKIM at the registrar and verifying in resend.com/domains.
RESEND_FROM="Berne Repair Leads <onboarding@resend.dev>"
# Lowercase — Resend sandbox does strict-case matching against the account email
LEAD_TO_EMAIL=bernerepair@gmail.com
# Production site URL (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://berne-repair.com

# Google Analytics 4 — leave blank to disable
# Get measurement ID at analytics.google.com → Admin → Data streams → Web → "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=
