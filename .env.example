# Resend — get key at https://resend.com/api-keys
RESEND_API_KEY=
# Sandbox until domain verified. Switch to "leads@berne-repair.com" after
# adding SPF/DKIM at the registrar and verifying in resend.com/domains.
RESEND_FROM="Berne Appliance Repair Leads <onboarding@resend.dev>"
# Lowercase — Resend sandbox does strict-case matching against the account email
LEAD_TO_EMAIL=bernerepair@gmail.com
# Production site URL (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.berne-repair.com

# Google Analytics 4. If unset, defaults to the production ID in app/layout.tsx.
# Override here (e.g. for staging) to point at a separate GA property.
NEXT_PUBLIC_GA_ID=G-5HM8N741LM

# Microsoft Clarity (heatmaps + session recordings + click maps).
# Get an ID from https://clarity.microsoft.com (one project per site).
# Leave empty to disable. Use "BERNE_PLACEHOLDER" to verify wiring without a real ID.
NEXT_PUBLIC_CLARITY_ID=

# Google Ads conversion tracking (gtag.js). The real production values are
# BAKED IN AS DEFAULTS in the code (they are public ids, present in the HTML
# of every page) — leave these empty; set them only to OVERRIDE the defaults,
# e.g. for a separate Ads account. No Vercel changes needed.
# Default tag ID: AW-18232464152 (components/site/google-ads-tag.tsx)
NEXT_PUBLIC_GADS_ID=
# "Calls from website" send_to — used in the website call tracking config
# (phone_conversion_number snippet), NOT a click event.
# Default: AW-18232464152/Ou0TCMyJqL0cEJim9fVD (components/site/google-ads-tag.tsx)
NEXT_PUBLIC_GADS_CALL_LABEL=
# "Lead form submit" send_to, fired on form success.
# Default: AW-18232464152/dCXNCM-JqL0cEJim9fVD (components/sections/lead-form.tsx)
NEXT_PUBLIC_GADS_LEAD_LABEL=
